# ============================================================
# ReelPulse — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA comite o arquivo .env no repositório.
# ============================================================

# --------------------------------------------------
# Frontend — Supabase (obrigatório)
# Encontre em: Supabase Dashboard > Project Settings > API
# --------------------------------------------------
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key_aqui

# --------------------------------------------------
# Edge Functions — Supabase Secrets (obrigatório)
# Configure em: Supabase Dashboard > Edge Functions > Secrets
# NÃO coloque essas variáveis no .env do frontend.
# --------------------------------------------------

# Service Role Key (acesso total ao banco, bypassar RLS)
# SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# URL do webhook n8n para processamento de reels
# Use o endpoint de PRODUÇÃO (/webhook/), não o de teste (/webhook-test/)
# N8N_WEBHOOK_URL=https://seu-n8n.dominio.com/webhook/ID_DO_WEBHOOK

# Segredo para autenticar chamadas do cron job do n8n
# Gere com: openssl rand -base64 32
# CRON_SECRET=string_aleatoria_e_segura_aqui

# Origem permitida para CORS (domínio do frontend em produção)
# ALLOWED_ORIGIN=https://seu-dominio.com

# --------------------------------------------------
# Desenvolvimento local (opcional)
# --------------------------------------------------
# Para demo em desenvolvimento apenas (NUNCA em produção)
# VITE_DEMO_EMAIL=demo@example.com
# VITE_DEMO_PASSWORD=senha_demo_aqui
